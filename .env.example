# ==============================================================
#  打出の小槌 - 認証情報設定ファイル
#  このファイルを .env にコピーして各値を入力してください
#  $ cp .env.example .env
# ==============================================================

# ── Twitter / X ───────────────────────────────────────────────
# https://developer.twitter.com でアプリを作成後に取得
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ── WordPress ─────────────────────────────────────────────────
# 管理画面 > ユーザー > プロフィール > アプリケーションパスワード で生成
WORDPRESS_URL=https://your-site.com
WORDPRESS_USERNAME=your_username
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
# 投稿ステータス: draft（下書き）または publish（即公開）
WORDPRESS_POST_STATUS=draft

# ── Amazon アソシエイト (PA API 5.0) ─────────────────────────
# https://affiliate.amazon.co.jp でPA API申請後に取得
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
AMAZON_PARTNER_TAG=your-associate-tag-22

# ── 楽天アフィリエイト ────────────────────────────────────────
# https://webservice.rakuten.co.jp でアプリ登録後に取得
RAKUTEN_APP_ID=
RAKUTEN_AFFILIATE_ID=

# ── システム設定 ──────────────────────────────────────────────
PROFIT_SCORE_THRESHOLD=50
CHECK_INTERVAL_SECONDS=600
